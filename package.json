{
    "name": "kysely-migration-example",
    "version": "1.0.0",
    "description": "An example of using Kysely migrations with TypeScript",
    "main": "dist/index.js",
    "scripts": {
        "migrate:up": "tsx watch src/index.ts up",
        "migrate:down": "tsx src/index.ts down",
        "build": "tsc && tsc-alias",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "biome:format": "npx @biomejs/biome format --write ./src",
        "biome:lint": "npx @biomejs/biome lint --write ./src",
        "biome:check": "npx @biomejs/biome check ./src",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.6.0",
        "tsx": "^4.21.0"
    },
    "dependencies": {
        "better-sqlite3": "^12.9.0",
        "kysely": "^0.28.16"
    }
}
